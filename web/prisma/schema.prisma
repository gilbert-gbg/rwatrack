generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  email        String     @unique
  password     String
  firstName    String
  lastName     String
  phone        String?
  avatar       String?
  bio          String?
  role         Role       @default(WORKER)
  institution  String?
  department   String?
  status       UserStatus @default(INACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  worker           Worker?
  managedWorkers   Worker[]         @relation("HRWorkers")
  auditLogs        AuditLog[]
  sessions         Session[]
  notifications    Notification[]
  sentMessages     Message[]        @relation("SentMessages")
  receivedMessages Message[]        @relation("ReceivedMessages")
  supportTickets   SupportTicket[]
}

model Worker {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique @db.ObjectId
  hrId            String?  @db.ObjectId
  jobTitle        String
  institution     String?
  department      String?
  homeLat         Float?
  homeLng         Float?
  homeAddress     String?
  workLat         Float?
  workLng         Float?
  workAddress     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hr              User?    @relation("HRWorkers", fields: [hrId], references: [id])
  locationLogs    LocationLog[]
  attendances     Attendance[]
}

model Attendance {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  workerId         String    @db.ObjectId
  date             String    // "2026-05-14"
  status           String    // PRESENT, ABSENT, LATE
  checkInTime      DateTime?
  checkInLat       Float?
  checkInLng       Float?
  distanceFromWork Float?
  createdAt        DateTime  @default(now())

  worker           Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model Message {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId    String   @db.ObjectId
  receiverId  String?  @db.ObjectId
  content     String
  broadcast   Boolean  @default(false)
  broadcastTo String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User?    @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model SupportTicket {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  subject     String
  message     String
  status      String   @default("OPEN")
  response    String?
  respondedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FraudAlert {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  description    String
  severity       String
  status         AlertStatus @default(OPEN)
  resolution     String?
  investigatedBy String?
  resolvedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model LocationLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  workerId   String   @db.ObjectId
  lat        Float
  lng        Float
  accuracy   Float?
  recordedAt DateTime @default(now())

  worker     Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  action    String
  resource  String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  HR
  WORKER
}

enum AlertStatus {
  OPEN
  INVESTIGATING
  RESOLVED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}
